rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for the 'users' collection
    match /users/{userId} {
      // By default, disallow read/write to user documents themselves
      allow read, write: if false;

      // Allow users to read and write to their own achievements subcollection.
      match /achievements/{achievementId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Default-deny rule for any other collection that is not explicitly defined.
    // This is a security best practice.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
